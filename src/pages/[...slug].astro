---
export const prerender = true;

export async function getStaticPaths() {
  // Return all possible paths for static generation
  // For a SPA with React Router, we return common base paths
  return [
    { params: { slug: '' } },
    { params: { slug: 'curriculum' } },
    { params: { slug: 'admission-process' } },
    { params: { slug: 'why-vr-robotics' } },
    { params: { slug: 'program-fees' } },
    { params: { slug: 'demo-booking' } },
    { params: { slug: 'student-signup' } },
    { params: { slug: 'teacher-portal' } },
    { params: { slug: 'teacher-dashboard' } },
    { params: { slug: 'certificates' } },
    { params: { slug: 'not-found' } },
  ];
}

import AppRouter from "@/components/Router";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>VR Robotics Academy</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        background: #f5f5f5;
      }
      #root {
        width: 100%;
        min-height: 100vh;
      }
    </style>
  </head>
  <body>
    <div id="root">
      <AppRouter client:only="react" />
    </div>
  </body>
</html>
